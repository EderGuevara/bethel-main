{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "gastos/index.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/admin", "destination": "https://exam.bethelfinancialgroup.com/admin", "permanent": false }
  ]
}
