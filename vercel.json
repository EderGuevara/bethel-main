{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "gastos/index.html", "use": "@vercel/static" },
    { "src": "forms/*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/forms/(.*)", "dest": "/forms/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/gastos", "dest": "/gastos/index.html" },
    { "src": "/interes-compuesto", "dest": "/interes-compuesto.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/portal", "dest": "/portal.html" },
    { "src": "/(.+\\.(?:jpg|jpeg|png|gif|svg|ico|webp|css|js|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
