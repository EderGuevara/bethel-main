{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/gastos", "destination": "/gastos.html" },
    { "source": "/expenses", "destination": "/gastos.html" },
    { "source": "/portal", "destination": "/portal.html" }
  ]
}
